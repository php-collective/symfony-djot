{
    "name": "php-collective/symfony-djot",
    "description": "Symfony bundle integration for php-collective/djot",
    "license": "MIT",
    "type": "symfony-bundle",
    "keywords": [
        "symfony",
        "bundle",
        "djot",
        "markup",
        "twig",
        "parser"
    ],
    "authors": [
        {
            "name": "PHP Collective",
            "homepage": "https://github.com/php-collective"
        }
    ],
    "homepage": "https://github.com/php-collective/symfony-djot",
    "require": {
        "php": "^8.2",
        "php-collective/djot": "^0.1",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/twig-bundle": "^6.4 || ^7.0",
        "symfony/validator": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5 || ^12.5 || ^13.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "PhpCollective\\SymfonyDjot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpCollective\\SymfonyDjot\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "stan": "phpstan analyse",
        "stan-setup": "composer require --dev phpstan/phpstan",
        "test": "phpunit"
    }
}
